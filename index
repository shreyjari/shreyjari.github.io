<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

<!-- PWA -->
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="RAP">
<meta name="theme-color" content="#080809">
<meta name="mobile-web-app-capable" content="yes">
<link rel="manifest" href="manifest.json">

<!-- SEO -->
<meta name="description" content="Live Rapaport diamond price list. Instant access for diamond merchants.">
<meta property="og:title" content="RAP · Diamond Prices">
<meta property="og:description" content="Live Rapaport price list for diamond merchants.">
<meta property="og:type" content="website">

<title>RAP · Diamond Prices</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">

<style>
/* ── RESET ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}

:root{
  --bg:    #080809;
  --bg2:   #0f0f11;
  --gold:  #c8a84b;
  --gold2: #8a6e2a;
  --gold3: rgba(200,168,75,.08);
  --tx:    #ede8de;
  --tx2:   #8a8680;
  --tx3:   #3e3d3a;
  --line:  #1c1c1f;
  --sat:   env(safe-area-inset-top,0px);
  --sab:   env(safe-area-inset-bottom,0px);
}

html{height:100%;background:var(--bg);scroll-behavior:smooth}
body{
  background:var(--bg);color:var(--tx);
  font-family:'DM Mono',monospace;
  min-height:100%;overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
  -webkit-text-size-adjust:100%;
}

/* ── GRAIN overlay ── */
body::before{
  content:'';
  position:fixed;inset:0;z-index:0;
  opacity:.028;pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:200px 200px;
}

/* ── LAYOUT ── */
.page{
  position:relative;z-index:1;
  min-height:100dvh;min-height:100vh;
  display:flex;flex-direction:column;
  padding-top:var(--sat);
  padding-bottom:calc(var(--sab) + 32px);
}

/* ── TOP BAR ── */
.topbar{
  display:flex;align-items:center;justify-content:space-between;
  padding:28px 32px 0;
}
.wordmark{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:18px;font-weight:600;letter-spacing:3px;
  text-transform:uppercase;color:var(--gold);
}
.version{
  font-size:9px;letter-spacing:2px;text-transform:uppercase;
  color:var(--tx3);font-weight:300;
}

/* ── HERO ── */
.hero{
  flex:1;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;
  padding:48px 28px;
  gap:0;
}

/* diamond geometric mark */
.diamond-mark{
  position:relative;
  width:72px;height:72px;
  margin-bottom:40px;
}
.diamond-mark svg{width:100%;height:100%}

/* headline */
.headline{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:clamp(42px,12vw,72px);
  font-weight:400;
  line-height:.95;
  letter-spacing:-.5px;
  color:var(--tx);
  margin-bottom:8px;
}
.headline em{
  font-style:italic;
  color:var(--gold);
}

/* sub */
.sub{
  font-size:11px;font-weight:300;
  letter-spacing:3px;text-transform:uppercase;
  color:var(--tx2);
  margin-bottom:52px;
  line-height:1.8;
}

/* CTA */
.cta{
  display:flex;flex-direction:column;
  align-items:center;gap:16px;
}

.btn-primary{
  display:inline-flex;align-items:center;gap:10px;
  background:var(--gold);color:#060607;
  font-family:'DM Mono',monospace;
  font-size:11px;font-weight:500;
  letter-spacing:2.5px;text-transform:uppercase;
  text-decoration:none;
  padding:16px 32px;
  border:none;cursor:pointer;
  position:relative;overflow:hidden;
  transition:background .2s,transform .15s;
  /* no border-radius — sharp like a cut diamond */
  -webkit-appearance:none;
  touch-action:manipulation;
  min-width:220px;justify-content:center;
  min-height:52px; /* 44pt+ touch target */
}
.btn-primary::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.12) 0%,transparent 60%);
  pointer-events:none;
}
.btn-primary:hover{background:#dfc06a;transform:translateY(-1px)}
.btn-primary:active{transform:translateY(0);background:#b8922e}

.btn-arrow{
  font-size:14px;letter-spacing:0;
  transition:transform .2s;
}
.btn-primary:hover .btn-arrow{transform:translateX(3px)}

.install-hint{
  font-size:10px;font-weight:300;
  color:var(--tx3);letter-spacing:1.5px;
  text-transform:uppercase;
}

/* ── FEATURES — three sparse lines ── */
.features{
  display:flex;flex-direction:column;
  gap:0;
  border-top:1px solid var(--line);
  margin-top:auto;
}
.feat{
  display:flex;align-items:center;gap:16px;
  padding:18px 32px;
  border-bottom:1px solid var(--line);
  opacity:0;
  animation:fadeUp .5s ease forwards;
}
.feat:nth-child(1){animation-delay:.6s}
.feat:nth-child(2){animation-delay:.75s}
.feat:nth-child(3){animation-delay:.9s}
.feat-num{
  font-size:9px;letter-spacing:1px;color:var(--gold2);
  font-weight:400;flex-shrink:0;width:16px;
}
.feat-txt{
  font-size:11px;font-weight:300;color:var(--tx2);
  letter-spacing:.5px;
}
.feat-txt b{color:var(--tx);font-weight:400}

/* ── ANIMATIONS ── */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(12px)}
  to  {opacity:1;transform:none}
}
.hero > *{
  opacity:0;animation:fadeUp .6s ease forwards;
}
.diamond-mark{animation-delay:.05s}
.headline     {animation-delay:.15s}
.sub          {animation-delay:.25s}
.cta          {animation-delay:.38s}

/* ── MOBILE tweaks ── */
@media(max-width:480px){
  .topbar{padding:20px 20px 0}
  .hero{padding:32px 20px}
  .feat{padding:16px 20px}
  .sub{margin-bottom:40px}
}

/* ── "Add to home screen" banner — shows only on iOS Safari ── */
.a2hs{
  display:none;
  position:fixed;
  bottom:calc(var(--sab) + 16px);
  left:16px;right:16px;
  background:rgba(18,18,20,.97);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:1px solid var(--line);
  padding:14px 16px;
  flex-direction:column;gap:4px;
  z-index:100;
  animation:fadeUp .3s ease;
}
.a2hs.show{display:flex}
.a2hs-title{font-size:12px;color:var(--tx);letter-spacing:.3px}
.a2hs-body{font-size:11px;font-weight:300;color:var(--tx2);letter-spacing:.2px;line-height:1.6}
.a2hs-close{
  position:absolute;top:12px;right:14px;
  background:none;border:none;color:var(--tx3);
  font-size:16px;cursor:pointer;padding:4px;
  line-height:1;
}
</style>
</head>
<body>
<div class="page">

  <!-- top bar -->
  <div class="topbar">
    <div class="wordmark">Rapaport</div>
    <div class="version">Price List</div>
  </div>

  <!-- hero -->
  <div class="hero">

    <!-- diamond SVG mark -->
    <div class="diamond-mark">
      <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- outer diamond outline -->
        <polygon points="36,4 68,36 36,68 4,36"
          stroke="#c8a84b" stroke-width="1" fill="none" opacity=".6"/>
        <!-- inner diamond -->
        <polygon points="36,16 56,36 36,56 16,36"
          stroke="#c8a84b" stroke-width=".6" fill="none" opacity=".35"/>
        <!-- girdle lines — facet suggestion -->
        <line x1="36" y1="4"  x2="36" y2="16" stroke="#c8a84b" stroke-width=".6" opacity=".4"/>
        <line x1="68" y1="36" x2="56" y2="36" stroke="#c8a84b" stroke-width=".6" opacity=".4"/>
        <line x1="36" y1="68" x2="36" y2="56" stroke="#c8a84b" stroke-width=".6" opacity=".4"/>
        <line x1="4"  y1="36" x2="16" y2="36" stroke="#c8a84b" stroke-width=".6" opacity=".4"/>
        <!-- corner diagonals -->
        <line x1="36" y1="4"  x2="56" y2="36" stroke="#c8a84b" stroke-width=".4" opacity=".2"/>
        <line x1="68" y1="36" x2="36" y2="56" stroke="#c8a84b" stroke-width=".4" opacity=".2"/>
        <line x1="36" y1="68" x2="16" y2="36" stroke="#c8a84b" stroke-width=".4" opacity=".2"/>
        <line x1="4"  y1="36" x2="36" y2="16" stroke="#c8a84b" stroke-width=".4" opacity=".2"/>
        <!-- centre dot -->
        <circle cx="36" cy="36" r="2" fill="#c8a84b" opacity=".5"/>
      </svg>
    </div>

    <h1 class="headline">Live<br><em>Diamond</em><br>Prices</h1>
    <p class="sub">Rapaport price list<br>for diamond merchants</p>

    <div class="cta">
      <a class="btn-primary" id="openApp" href="#" target="_blank" rel="noopener">
        Open Price List
        <span class="btn-arrow">→</span>
      </a>
      <p class="install-hint" id="installHint">Add to home screen for instant access</p>
    </div>

  </div>

  <!-- feature strip -->
  <div class="features">
    <div class="feat">
      <span class="feat-num">01</span>
      <span class="feat-txt"><b>All 10 shapes</b> — Round, Pear, Oval &amp; more</span>
    </div>
    <div class="feat">
      <span class="feat-num">02</span>
      <span class="feat-txt"><b>Tap to copy</b> — share prices on WhatsApp instantly</span>
    </div>
    <div class="feat">
      <span class="feat-num">03</span>
      <span class="feat-txt"><b>Live Rapnet data</b> — always the current week's list</span>
    </div>
  </div>

</div>

<!-- iOS Add to Home Screen nudge -->
<div class="a2hs" id="a2hs">
  <button class="a2hs-close" onclick="dismissA2HS()">×</button>
  <div class="a2hs-title">Add to Home Screen</div>
  <div class="a2hs-body">
    Tap <strong>Share</strong> then <strong>"Add to Home Screen"</strong> for one-tap access.
  </div>
</div>

<script>
// ── Inject your GAS deployment URL here ──
var GAS_URL = 'https://script.google.com/macros/s/AKfycbzmM-HPa_Pv2kd2OITSja_Ux3EHyZn3GVyZzK2PENk5FNOenJ8EGgZcmoom_K05uBD1/exec';

document.getElementById('openApp').href = GAS_URL;

// ── iOS "Add to Home Screen" nudge ──
// Show only on iOS Safari, not in standalone mode, not if dismissed before
var isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
var isStandalone = window.navigator.standalone === true;
var dismissed = localStorage.getItem('a2hs-dismissed');

if(isIOS && !isStandalone && !dismissed){
  // Delay so it doesn't compete with page load
  setTimeout(function(){
    document.getElementById('a2hs').classList.add('show');
    // also update the hint text
    document.getElementById('installHint').textContent = '↓ See tip below to install';
  }, 2200);
}

// If already running as standalone (added to home screen)
if(isStandalone){
  // Auto-redirect straight to the app
  window.location.href = GAS_URL;
}

function dismissA2HS(){
  document.getElementById('a2hs').classList.remove('show');
  localStorage.setItem('a2hs-dismissed','1');
}
</script>
</body>
</html>
